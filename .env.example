# Local host-run defaults.
# Docker Compose overrides REDIS_URL and DATABASE_URL to service hostnames inside the Docker Compose network.
APP_ENV="dev"
APP_HOST="0.0.0.0"
APP_PORT=8080
APP_LOG_LEVEL="INFO"
APP_RATE_LIMIT_PER_MINUTE=30
APP_WEBHOOK_SECRET="example"

OPENAI_API_KEY="example"
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_TIMEOUT_SECONDS=2.2
OPENAI_MAX_RETRIES=1
OPENAI_WEB_SEARCH_ENABLED=true
OPENAI_WEB_SEARCH_CONTEXT_SIZE="low"
OPENAI_SYSTEM_PROMPT="You are the backend for a Yandex Alice voice skill. Reply in Russian unless the user clearly asks for another language. Return one short spoken answer in plain text. Sound natural and direct. Give a useful answer immediately when possible. If uncertain, say so briefly. Do not repeat the user's question unless needed. Do not use markdown, lists, headings, code, meta commentary, or bracketed service syntax."

REDIS_URL="redis://localhost:6379/0"
REDIS_PREFIX="yandex-alice-openai"
REDIS_SESSION_TTL_SECONDS=86400
REDIS_SESSION_TURN_LIMIT=24
REDIS_PENDING_TTL_SECONDS=1800
REDIS_IDEMPOTENCY_TTL_SECONDS=900
REDIS_RATE_LIMIT_WINDOW_SECONDS=60

DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/yandex_alice_openai"
DATABASE_ECHO=false

WORKER_POLL_TIMEOUT_MS=3000
WORKER_IDLE_SLEEP_SECONDS=1.0
WORKER_JOB_TIMEOUT_SECONDS=20.0
